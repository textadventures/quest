{
  "name": "quest-viva-desktop",
  "version": "0.0.1",
  "private": true,
  "author": "Alex Warren",
  "main": "dist/main.js",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "copy-static": "node scripts/copy-static.mjs",
    "build": "npm run build:ts && npm run copy-static",
    "start": "npm run build && electron .",
    "dist": "npm run build && node scripts/dist.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "^7.0.2"
  },
  "build": {
    "appId": "com.questviva.desktop",
    "productName": "Quest Viva",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/app-static",
        "to": "app-static"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64", "arm64"]
        }
      ]
    }
  }
}
