@page "/editor/{Id}/{File}"
@using QuestViva.Common
@attribute [RequiresConfig("Editor:Enabled")]
@rendermode InteractiveServer
@inject HttpClient HttpClient
@inject Config Config

<Game GameDataProvider="GetGameDataProvider()" ResourceUrlProvider="GetResourceUrlProvider" EnableDebug="true"
      EnableSave="false"></Game>

@code {
    [Parameter] public required string Id { get; set; }
    [Parameter] public required string File { get; set; }

    private IGameDataProvider GetGameDataProvider()
    {
        return new UrlGameDataProvider(HttpClient, $"{Config.EditorBlobStorageRoot}{Id}/{File}");
    }

    private IResourceUrlProvider GetResourceUrlProvider(GameData gameData)
    {
        return new RemoteResourceUrlProvider($"{Config.EditorBlobStorageRoot}{Id}/");
    }

}