<asl version="580">
  <include ref="English.aslx" />
  <include ref="Core.aslx" />
  <game name="callbacktest"/>
  <object name="start">
    <object name="player">
      <inherit name="defaultplayer" />
    </object>
  </object>

  <!-- GetInput() function form: script suspends until user responds -->
  <command name="cmd_getinput">
    <pattern>getinput</pattern>
    <script>
      msg ("before input")
      x = GetInput()
      msg ("got: " + x)
    </script>
  </command>

  <!-- get input script form: script continues past the block; callback runs after response -->
  <command name="cmd_getinputscript">
    <pattern>getinputscript</pattern>
    <script>
      msg ("before input")
      get input {
        msg ("got: " + result)
      }
      msg ("after input block")
    </script>
  </command>

  <!-- wait: script continues past the block; callback and on ready run after key press -->
  <command name="cmd_wait">
    <pattern>testwait</pattern>
    <script>
      msg ("before wait")
      wait {
        msg ("wait done")
      }
      msg ("after wait block")
      on ready {
        msg ("on ready")
      }
    </script>
  </command>

  <!-- nested on ready: inner on ready should queue and run after the outer callback
       completes, not nested inside it. Before the AddOnReady fix this would either
       produce the wrong order (inner before "outer after") or stack-overflow when
       the nesting was unbounded. -->
  <command name="cmd_nested_on_ready">
    <pattern>nestedonready</pattern>
    <script>
      on ready {
        msg ("outer before")
        on ready {
          msg ("inner")
        }
        msg ("outer after")
      }
      msg ("after block")
    </script>
  </command>
</asl>
